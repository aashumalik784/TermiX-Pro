#!/bin/bash
# Start TermiX-Pro Web Dashboard

echo "🌐 Starting TermiX-Pro Web Dashboard..."

proot-distro login ubuntu -- bash -c "
    # Create web dashboard
    mkdir -p /var/www/html /var/www/cgi-bin
    
    cat > /var/www/html/index.html << 'HTMLEOF'
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TermiX-Pro Dashboard</title>
    <style>
        body { background: #000; color: #0f0; font-family: 'Courier New', monospace; padding: 20px; margin: 0; }
        h1 { border-bottom: 2px solid #0f0; padding-bottom: 10px; color: #0f0; text-align: center; }
        h2 { color: #fff; margin-top: 25px; border-left: 5px solid #0f0; padding-left: 10px; }
        .status { background: #111; padding: 15px; border-radius: 5px; margin-bottom: 20px; border: 1px solid #0f0; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; margin-top: 10px; }
        .btn { padding: 12px; border: 1px solid #0f0; color: #0f0; text-decoration: none; text-align: center; background: transparent; cursor: pointer; display: block; border-radius: 3px; transition: all 0.3s; }
        .btn:hover { background: #0f0; color: #000; font-weight: bold; }
        .btn.installed { border-color: #0f0; background: #001100; }
        .footer { margin-top: 30px; text-align: center; color: #666; font-size: 12px; }
    </style>
</head>
<body>
    <h1>🚀 TermiX-Pro Dashboard</h1>
    <div class="status">
        <strong>✅ System Status:</strong> Fully Operational<br>
        <strong>🛠️ Tools Installed:</strong> 14/15 Ready<br>
        <strong>🌐 Server:</strong> Nginx 1.28.3 + CGI<br>
        <strong>💾 Environment:</strong> Ubuntu (Proot-Distro x86_64)
    </div>
    <h2>📌 Programming Languages (10 Tools)</h2>
    <div class="grid">
        <a href="/cgi-bin/execute.sh?tool=python" class="btn installed">Python 3.14 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=java" class="btn installed">Java 25 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=g++" class="btn installed">C++ GCC 15 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=node" class="btn installed">Node.js 22 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=php" class="btn installed">PHP 8.5 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=go" class="btn installed">Go 1.26 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=rust" class="btn installed">Rust 1.93 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=ruby" class="btn installed">Ruby 3.3 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=kotlin" class="btn installed">Kotlin ✅</a>
        <a href="/cgi-bin/execute.sh?tool=dart" class="btn installed">Dart 3.5 ✅</a>
    </div>
    <h2>🌐 Web, Server & Cloud (4 Tools)</h2>
    <div class="grid">
        <a href="/cgi-bin/execute.sh?tool=nginx" class="btn installed">Nginx 1.28 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=docker" class="btn installed">Docker 29.1 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=react" class="btn">React (NPM)</a>
        <a href="/cgi-bin/execute.sh?tool=html" class="btn">HTML/CSS</a>
    </div>
    <h2>🗄️ Databases (2 Tools)</h2>
    <div class="grid">
        <a href="/cgi-bin/execute.sh?tool=mysql" class="btn installed">MySQL 8.4 ✅</a>
        <a href="/cgi-bin/execute.sh?tool=postgresql" class="btn installed">PostgreSQL 18 ✅</a>
    </div>
    <div class="footer">
        <p>TermiX-Pro v1.0 | Built with ❤️ in Termux</p>
        <p>14/15 Tools Operational</p>
    </div>
</body>
</html>
HTMLEOF

    # Create CGI script
    cat > /var/www/cgi-bin/execute.sh << 'CGIEOF'
#!/bin/bash
echo "Content-Type: text/html"
echo ""
TOOL=\$(echo \$QUERY_STRING | cut -d'=' -f2)
echo "<html><head><title>TermiX-Pro: \$TOOL</title><style>body{background:#000;color:#0f0;font-family:monospace;padding:20px;} a{color:#0f0;}</style></head><body>"
echo "<h1>🚀 Tool Status: \$TOOL</h1>"
case \$TOOL in
    python|python3) echo "<p><strong>✅ Python</strong></p><pre>\$(python3 --version 2>&1)</pre>" ;;
    java) echo "<p><strong>✅ Java</strong></p><pre>\$(java -version 2>&1)</pre>" ;;
    g++) echo "<p><strong>✅ C++</strong></p><pre>\$(g++ --version | head -n 1)</pre>" ;;
    node) echo "<p><strong>✅ Node.js</strong></p><pre>\$(node --version)</pre>" ;;
    php) echo "<p><strong>✅ PHP</strong></p><pre>\$(php -v | head -n 1)</pre>" ;;
    go) echo "<p><strong>✅ Go</strong></p><pre>\$(go version)</pre>" ;;
    rust) echo "<p><strong>✅ Rust</strong></p><pre>\$(rustc --version)</pre>" ;;
    ruby) echo "<p><strong>✅ Ruby</strong></p><pre>\$(ruby --version)</pre>" ;;
    kotlin) echo "<p><strong>✅ Kotlin</strong></p><pre>\$(kotlinc -version 2>&1 | head -n 1)</pre>" ;;
    dart) echo "<p><strong>✅ Dart</strong></p><pre>\$(dart --version)</pre>" ;;
    nginx) echo "<p><strong>✅ Nginx</strong></p><pre>\$(nginx -v 2>&1)</pre>" ;;
    docker) echo "<p><strong>✅ Docker</strong></p><pre>\$(docker --version)</pre>" ;;
    mysql) echo "<p><strong>✅ MySQL</strong></p><pre>\$(mysql --version)</pre>" ;;
    postgresql|psql) echo "<p><strong>✅ PostgreSQL</strong></p><pre>\$(psql --version)</pre>" ;;
    *) echo "<p>Checking \$TOOL...</p><pre>which \$TOOL 2>&1 || echo 'Not found'</pre>" ;;
esac
echo "<br><a href='/'>️ Back to Dashboard</a></body></html>"
CGIEOF

    chmod +x /var/www/cgi-bin/execute.sh
    
    # Start services
    nginx
    spawn-fcgi -s /run/fcgiwrap.socket -M 766 -- /usr/sbin/fcgiwrap
    
    echo '✅ Web Dashboard is LIVE!'
    echo ' Open browser: http://localhost:8080'
"
