#!/system/bin/sh
# Start TermiX-Pro Web Dashboard

echo "🌐 Starting TermiX-Pro Web Dashboard..."

proot-distro login ubuntu -- bash -c "
    # Create web dashboard
    mkdir -p /var/www/html /var/www/cgi-bin
    
    # Copy dashboard files from assets if available
    if [ -f /data/data/com.termux/files/usr/share/termix-pro/index.html ]; then
        cp /data/data/com.termux/files/usr/share/termix-pro/index.html /var/www/html/
        cp /data/data/com.termux/files/usr/share/termix-pro/execute.sh /var/www/cgi-bin/
    fi
    
    # Start services
    nginx
    spawn-fcgi -s /run/fcgiwrap.socket -M 766 -- /usr/sbin/fcgiwrap
    
    echo '✅ Web Dashboard is LIVE!'
    echo '🌍 Open browser: http://localhost:8080'
"
